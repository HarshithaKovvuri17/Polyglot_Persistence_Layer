# Application Config
PORT=3000
LOG_FILE_PATH=/app/events.log
RETRY_QUEUE_PATH=/app/retry_queue.json
RECONCILER_INTERVAL_MS=5000

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=logistics_billing

# MongoDB Configuration
MONGO_URI=mongodb://mongo_user:mongo_secure_pass@mongo:27017/logistics_documents?authSource=admin
MONGO_DB_NAME=logistics_documents

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secure_pass
